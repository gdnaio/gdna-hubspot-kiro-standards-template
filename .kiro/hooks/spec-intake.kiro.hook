{\n  "name": "spec-intake",\n  "version": "1.0.0",\n  "enabled": true,\n  "description": "Fires when Cowork drops a new spec into .kiro/specs/ - auto-starts the agent on it",\n  "when": {\n    "type": "fileCreate",\n    "filePattern": ".kiro/specs/**/*.md"\n  },\n  "then": {\n    "type": "askAgent",\n    "prompt": "A new spec file has been created. Read it now and begin executing the tasks defined in it. Start with requirements.md if it exists, then design.md, then tasks.md. Work through each task in sequence without waiting for user input unless you hit a genuine blocker. Log your progress to .kiro/state/session-state.json after each task."\n  }\n}\n