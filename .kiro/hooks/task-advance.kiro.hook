{\n  "name": "task-advance",\n  "version": "1.0.0",\n  "enabled": true,\n  "description": "After each spec task completes, check for the next task and continue without waiting",\n  "when": {\n    "type": "postTaskExecution"\n  },\n  "then": {\n    "type": "askAgent",\n    "prompt": "The previous task has completed. Check tasks.md for the next incomplete task (marked [ ] not [x]). If one exists, begin it immediately. If all tasks are complete, update .kiro/state/session-state.json with status: complete and a summary of what was built, then stop."\n  }\n}\n